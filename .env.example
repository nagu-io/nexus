# Optional: Supabase persistent memory
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Optional: Groq for live ReflectScore scoring
GROQ_API_KEY=your-groq-api-key

# Optional: Anthropic cloud fallback
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: CanaryVaults remote monitoring
CANARYVAULTS_API_URL=https://canaryvaults.com/api
CANARYVAULTS_API_KEY=your-canaryvaults-key

# Required for local model execution
OLLAMA_BASE_URL=http://localhost:11434

# Core NEXUS settings
NEXUS_MODEL=phi3:mini
# Legacy compatibility knob used as a fallback only
NEXUS_REFLECT_THRESHOLD=0.5
NEXUS_ROUTER_COMPLEXITY_THRESHOLD=0.5
NEXUS_REFLECT_WARN_THRESHOLD=0.3
NEXUS_REFLECT_BLOCK_THRESHOLD=0.6
NEXUS_DATA_DIR=~/.nexus
NEXUS_CONTEXT_REDUCTION_ENABLED=true
NEXUS_CONTEXT_REDUCTION_BACKEND=heuristic
NEXUS_CONTEXT_REDUCTION_THRESHOLD_CHARS=12000
NEXUS_CONTEXT_REDUCTION_TARGET_CHARS=6000
# Optional future backend selection for sequence models like Mamba
NEXUS_CONTEXT_REDUCTION_MODEL=

# Dashboard frontend
VITE_API_URL=http://localhost:8000
